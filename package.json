{
  "name": "react-window-modals",
  "version": "0.1.1",
  "description": "A flexible, customizable, and lightweight React library for creating draggable, resizable, and context-managed window modals.",
  "author": "hazimalperata",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "react",
    "modal",
    "window",
    "draggable",
    "resizable",
    "floating",
    "react-component"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build:dev": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build": "tsup src/index.ts --format cjs,esm --dts"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "packageManager": "yarn@1.22.22"
}
